<?xml version="1.0" encoding="UTF-8"?>
<definitions
        xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
        xmlns:activiti="http://activiti.org/bpmn"
        targetNamespace="http://example.com/workflow">

    <process id="googleDocWorkflow"
             name="Google Doc Workflow (v1.2)"
             isExecutable="true">

        <startEvent id="startEvent" activiti:formKey="tawf:startGoogleDoc">
            <extensionElements>
                <activiti:executionListener
                        event="start"
                        class="ua.edu.onu.workflow.CreateGoogleDocDelegate"/>
            </extensionElements>
        </startEvent>

        <userTask id="userTask" name="User task" activiti:formKey="tawf:googleDocTask">
            <humanPerformer>
                <resourceAssignmentExpression>
                    <formalExpression>${bpm_assignee.properties.userName}</formalExpression>
                </resourceAssignmentExpression>
            </humanPerformer>
        </userTask>

        <endEvent id="endEvent" />

        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="userTask"/>
        <sequenceFlow id="flow3" sourceRef="userTask" targetRef="endEvent"/>

    </process>
</definitions>
